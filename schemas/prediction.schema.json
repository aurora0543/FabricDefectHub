{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://fabricdefecthub/schemas/prediction.schema.json",
  "title": "Prediction",
  "description": "Unified per-image model output. Backends populate only the fields they produce.",
  "type": "object",
  "required": ["sample_id"],
  "properties": {
    "sample_id": { "type": "string" },
    "boxes": {
      "type": ["array", "null"],
      "items": { "type": "array", "items": { "type": "number" }, "minItems": 4, "maxItems": 4 }
    },
    "labels": { "type": ["array", "null"], "items": { "type": "string" } },
    "scores": { "type": ["array", "null"], "items": { "type": "number" } },
    "masks": { "type": ["array", "null"] },
    "anomaly_score": { "type": ["number", "null"] },
    "anomaly_map": { "type": ["string", "null"] }
  },
  "additionalProperties": false
}
